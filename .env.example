# Blue Carbon Registry Settings
PROJECT_NAME="Blue Carbon Registry & MRV System"

# Database Configuration
# Use local sqlite for simple test or postgres in docker-compose
DATABASE_URL=sqlite:///./blue_carbon.db
# DATABASE_URL=postgresql://postgres:postgres@db:5432/bluecarbon

# JWT Authentication Secret
JWT_SECRET=supersecretjwtkeyforbluecarbonregistry2026

# Redis Broker (Celery Background Tasks)
REDIS_URL=redis://localhost:6379/0

# Blockchain JSON-RPC Provider
RPC_URL=http://localhost:8545
# RPC_URL=http://hardhat:8545 (inside docker-compose)

# Smart Contract Minter / Admin Private Key (Hardhat Account #0)
ADMIN_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# IPFS Pinning Provider (Pinata)
PINATA_API_KEY=
PINATA_API_SECRET=

# MRV Mode (Set to False to query actual Sentinel-2 satellite data via GEE)
MOCK_MODE=True

# SMTP Mail Notifications (Optional)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=
